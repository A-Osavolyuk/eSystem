@page "/account/email/verify"

@using eSecurity.Client.Common.Validation.Validators
@using eSecurity.Client.Security.Identity
@using eSecurity.Core.Requests.Email.Verification

@inherits PageBase

@inject VerifyEmailValidator Validator
@inject IEmailService EmailService

@attribute [Authorize]

<PageTitle>Email verification</PageTitle>

<MudGrid Justify="Justify.Center" Spacing="1">
    <MudItem xs="3" Style="margin-top: 100px">
        <MudStack Spacing="1" Justify="Justify.Center">
            <MudPaper Outlined Class="pt-4 pb-2 px-5">
                <MudStack Spacing="3">
                    <MudTextM3 Align="Align.Center" Typo="TypoM3.Headline" Size="Size.Small">
                        Email verification
                    </MudTextM3>
                    <MudTextM3 Align="Align.Center" Typo="TypoM3.Body" Size="Size.Medium">
                        We have sent an email with 6-digit code to email:
                        <strong>@Email</strong>
                    </MudTextM3>
                    <MudStack Spacing="2" Justify="Justify.Center">
                        <MudForm
                            @ref="_form"
                            Model="_model"
                            Validation="Validator.ValidateValue">
                            <MudTextField
                                @bind-Value="_model.Code"
                                Variant="Variant.Outlined"
                                Placeholder="XXXXXX"
                                Mask="_mask"
                                Clearable="true"
                                Immediate="true"/>
                        </MudForm>
                        <MudLoadingButton
                            ButtonType="ButtonType.Button"
                            Variant="Variant.Filled"
                            Color="Color.Primary"
                            Size="Size.Medium"
                            Disabled="@(_model.Code.Length <= 5)"
                            OnClick="@(async () => await OnVerifyAsync())">
                            Verify
                        </MudLoadingButton>
                        <MudButton
                            Size="Size.Medium"
                            Variant="Variant.Text"
                            Color="Color.Info"
                            ButtonType="ButtonType.Button"
                            Href="@ReturnUrl"
                            OnClick="@(() => NavigationManager.NavigateTo(ReturnUrl))">
                            Cancel
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
            @if (_canResend)
            {
                <MudPaper Outlined="true" Class="pa-3">
                    <MudTextM3 Align="Align.Center" Typo="TypoM3.Body" Size="Size.Medium">
                        Didn't received an email?
                        <MudLink Typo="Typo.body2" OnClick="@(async () => await OnResendAsync())">
                            Resend
                        </MudLink>
                    </MudTextM3>
                </MudPaper>
            }
        </MudStack>
    </MudItem>
</MudGrid>

@code {

    [SupplyParameterFromQuery(Name = "return_url")]
    public string ReturnUrl { get; set; } = null!;

    [SupplyParameterFromQuery(Name = "email")]
    private string Email { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "type")]
    private string Type { get; set; } = string.Empty;

    private readonly VerifyEmailModel _model = new();

    private readonly PatternMask _mask = new("000000");
    private MudForm _form = new();
    private bool _canResend = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var request = new SendEmailVerificationRequest { Email = Email };
            var response = await EmailService.SendEmailVerificationAsync(request);
            if (response.Succeeded)
            {
                _canResend = true;
                StateHasChanged();
            }
            else
            {
                var error = response.GetError();
                Snackbar.Add(error.Description, Severity.Error);
            }
        }
    }

    private async Task OnResendAsync()
    {
        var request = new ResendEmailVerificationRequest { Email = Email };
        var result = await EmailService.ResendEmailVerificationAsync(request);
        if (!result.Succeeded)
        {
            var error = result.GetError();
            Snackbar.Add(error.Description, Severity.Error);
        }
    }

    private async Task OnVerifyAsync()
    {
        await _form.ValidateAsync();

        if (_form.IsValid)
        {
            var request = new ConfirmEmailVerificationRequest()
            {
                Code = _model.Code,
                Email = Email
            };

            var result = await EmailService.ConfirmEmailVerificationAsync(request);
            if (result.Succeeded)
            {
                NavigationManager.NavigateTo(ReturnUrl);
            }
            else
            {
                var error = result.GetError();
                Snackbar.Add(error.Description, Severity.Error);
            }
        }
    }

}