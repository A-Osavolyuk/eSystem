@page "/account/email/manage"

@using eSecurity.Client.Common.Validation.Validators
@using eSecurity.Client.Security.Authorization.Verification
@using eSecurity.Client.Security.Identity
@using eSecurity.Core.Requests.Email.Change
@using eSecurity.Core.Requests.Verification
@using eSecurity.Core.Responses.Verification

@inherits PageBase

@attribute [Authorize]

@inject CodeModelValidator Validator
@inject IEmailService EmailService
@inject IVerificationService VerificationService

<PageTitle>Manage email</PageTitle>

<MudGrid Justify="Justify.Center" Spacing="1">
    <MudItem xs="3" Style="margin-top: 100px">
        <MudStack Spacing="1" Justify="Justify.Center">
            <MudPaper Outlined Class="px-5 pt-4 pb-2">
                <MudStack Spacing="3" Justify="Justify.Center">
                    <MudTextM3 Align="Align.Center" Size="Size.Small" Typo="TypoM3.Headline">
                        Manage email
                    </MudTextM3>
                    <MudTextM3 Align="Align.Center" Typo="TypoM3.Body" Size="Size.Medium">
                        We have sent an email with 6-digit code to:
                        <strong>@UserState.Email!</strong>
                    </MudTextM3>
                    <MudStack Spacing="2">
                        <MudForm
                            @ref="_form"
                            Model="_model"
                            Validation="Validator.ValidateValue">
                            <MudTextField
                                @bind-Value="_model.Code"
                                Variant="Variant.Outlined"
                                Placeholder="XXXXXX"
                                Mask="_mask"
                                Clearable="true"
                                Immediate="true"/>
                        </MudForm>
                        <MudLoadingButton
                            ButtonType="ButtonType.Button"
                            Variant="Variant.Filled"
                            Color="Color.Primary"
                            Size="Size.Medium"
                            FullWidth
                            Disabled="@(_model.Code.Length <= 5)"
                            OnClick="@(async () => await OnVerifyAsync())">
                            Verify
                        </MudLoadingButton>
                        <MudButton
                            ButtonType="ButtonType.Button"
                            Variant="Variant.Text"
                            Color="Color.Info"
                            Size="Size.Medium"
                            FullWidth
                            Href="@ReturnUrl">
                            Cancel
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
            @if (_canResend)
            {
                <MudPaper Outlined="true" Class="pa-3">
                    <MudTextM3 Align="Align.Center" Typo="TypoM3.Body" Size="Size.Medium">
                        Didn't received an email?
                        <MudLink Typo="Typo.body2" OnClick="@(async () => await OnResendAsync())">
                            Resend
                        </MudLink>
                    </MudTextM3>
                </MudPaper>
            }
        </MudStack>
    </MudItem>
</MudGrid>

@code {

    [SupplyParameterFromQuery(Name = "current_email")]
    public string CurrentEmail { get; set; } = string.Empty;
    
    [SupplyParameterFromQuery(Name = "new_email")]
    public string NewEmail { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "return_url")]
    public string ReturnUrl { get; set; } = string.Empty;

    private CodeModel _model = new();
    private MudForm _form = new();
    private bool _canResend = false;
    private PatternMask _mask = new("000000");
    private Guid _verificationId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var request = new SendEmailChangeOtpRequest()
            {
                NewEmail = NewEmail
            };
            
            var result = await EmailService.SendEmailChangeAsync(request);
            if (result.Succeeded && result.TryGetValue<SendEmailOtpResponse>(out var response))
            {
                _verificationId = response.VerificationId;
                _canResend = true;
                StateHasChanged();
            }
            else
            {
                var error = result.GetError();
                Snackbar.Add(error.Description, Severity.Error);
            }
        }
    }

    private async Task OnResendAsync()
    {
        var request = new ResendEmailOtpRequest { VerificationId = _verificationId };
        var result = await VerificationService.ResendEmailOtpAsync(request);
        if (!result.Succeeded)
        {
            var error = result.GetError();
            Snackbar.Add(error.Description, Severity.Error);
        }
    }

    private async Task OnVerifyAsync()
    {
        await _form.ValidateAsync();

        if (_form.IsValid)
        {
            var request = new ChangeEmailRequest()
            {
                VerificationId = _verificationId,
                Code = _model.Code,
                CurrentEmail = CurrentEmail,
                NewEmail = NewEmail
            };

            var result = await EmailService.ChangeEmailAsync(request);

            if (result.Succeeded)
            {
                NavigationManager.NavigateTo(ReturnUrl);
            }
            else
            {
                var error = result.GetError();
                Snackbar.Add(error.Description, Severity.Error);
            }
        }
    }

}