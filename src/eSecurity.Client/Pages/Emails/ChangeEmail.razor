@page "/account/email/change"
@using eSecurity.Client.Common.Confirmation
@using eSecurity.Client.Common.Validation.Validators
@using eSecurity.Client.Security.Identity
@using eSecurity.Core.Requests.Email.Change
@using eSecurity.Core.Security.Identity.Constants

@inherits PageBase

@attribute [Authorize]

@inject ChangeEmailValidator ChangeEmailValidator
@inject CodeModelValidator Validator
@inject IEmailService EmailService

@switch (Type)
{
    case EmailTypes.Primary:
        <PageTitle>Primary email change</PageTitle> break;
    case EmailTypes.Recovery:
        <PageTitle>Recovery email change</PageTitle> break;
}

<AccessConfirmation Context="_confirmationContext">
    <AccessConfirmed>
        <MudGrid Justify="Justify.Center">
            <MudItem xs="6" Style="margin-top: 100px">
                <MudStepperExtended @ref="_stepper" Color="Color.Primary" Variant="Variant.Filled"
                                    HeaderTextView="HeaderTextView.All" HeaderBadgeView="HeaderBadgeView.All"
                                    ShowNextButton="false" ShowPreviousButton="false" ShowSkipButton="false">
                    <ChildContent>
                        <MudStepExtended Order="0" Icon="@Icons.Material.Filled.Start" Title="Request">
                            <ChildContent>
                                <MudGrid Justify="Justify.Center">
                                    <MudItem xs="8">
                                        <MudStack Spacing="1">
                                            <MudPaper Outlined Class="pa-3">
                                                @switch (Type)
                                                {
                                                    case EmailTypes.Primary:
                                                    {
                                                        <MudTextM3 Align="Align.Center" Typo="TypoM3.Headline"
                                                                   Size="Size.Small">
                                                            Primary email change
                                                        </MudTextM3>

                                                        break;
                                                    }
                                                    case EmailTypes.Recovery:
                                                    {
                                                        <MudTextM3 Align="Align.Center" Typo="TypoM3.Headline"
                                                                   Size="Size.Small">
                                                            Recovery email change
                                                        </MudTextM3>

                                                        break;
                                                    }
                                                }
                                            </MudPaper>
                                            <MudPaper Outlined="true" Class="px-5 py-4">
                                                <MudStack Spacing="2">
                                                    @switch (Type)
                                                    {
                                                        case EmailTypes.Primary:
                                                        {
                                                            <MudTextM3 Typo="TypoM3.Body" Size="Size.Medium">
                                                                To change your current primary email address,
                                                                you need to enter new email address,
                                                                then we will send emails with verification code to your
                                                                current and new primary email addresses.
                                                            </MudTextM3>

                                                            break;
                                                        }
                                                        case EmailTypes.Recovery:
                                                        {
                                                            <MudTextM3 Typo="TypoM3.Body" Size="Size.Medium">
                                                                To change your current recovery email address,
                                                                you need to enter new email address,
                                                                then we will send emails with verification code to your
                                                                current and new recovery email addresses.
                                                            </MudTextM3>

                                                            break;
                                                        }
                                                    }
                                                    <MudForm
                                                        @ref="_changeForm"
                                                        Model="_changeModel"
                                                        Validation="ChangeEmailValidator.ValidateValue">
                                                        <MudTextFieldExtended
                                                            Margin="Margin.Dense"
                                                            @bind-Value="_changeModel.NewEmail"
                                                            For="() => _changeModel.NewEmail"
                                                            Label="New email"
                                                            Variant="Variant.Outlined"
                                                            Immediate="true"
                                                            Clearable="true"/>
                                                    </MudForm>
                                                    <MudLoadingButton
                                                        Size="Size.Small"
                                                        Variant="Variant.Filled"
                                                        Color="Color.Success"
                                                        ButtonType="ButtonType.Button"
                                                        OnClick="@(async () => await OnSendCode())">
                                                        Change
                                                    </MudLoadingButton>
                                                    <MudButton
                                                        Size="Size.Small"
                                                        Variant="Variant.Text"
                                                        Color="Color.Info"
                                                        ButtonType="ButtonType.Button"
                                                        Href="@ReturnUrl"
                                                        OnClick="@(() => NavigationManager.NavigateTo(ReturnUrl))">
                                                        Cancel
                                                    </MudButton>
                                                </MudStack>
                                            </MudPaper>
                                        </MudStack>
                                    </MudItem>
                                </MudGrid>
                            </ChildContent>
                        </MudStepExtended>
                        <MudStepExtended Order="1" Icon="@Icons.Material.Filled.Check" Title="Verification">
                            <ChildContent>
                                <MudGrid Justify="Justify.Center">
                                    <MudItem xs="8">
                                        <MudStack Spacing="1" Justify="Justify.Center">
                                            <MudPaper Outlined="true" Class="pa-3">
                                                <MudTextM3 Align="Align.Center" Typo="TypoM3.Headline" Size="Size.Small">
                                                    Email verification
                                                </MudTextM3>
                                            </MudPaper>
                                            <MudPaper Outlined="true" Class="px-5 py-4">
                                                <MudStack Spacing="2">
                                                    <MudTextM3 Align="Align.Center" Typo="TypoM3.Body" Size="Size.Medium">
                                                        Enter 6-digit code from letter we sent you
                                                        to: @_changeModel.NewEmail
                                                    </MudTextM3>
                                                    <MudForm
                                                        @ref="_confirmForm"
                                                        Model="_confirmModel"
                                                        Validation="Validator.ValidateValue">
                                                        <MudTextFieldExtended
                                                            @bind-Value="_confirmModel.Code"
                                                            Variant="Variant.Outlined"
                                                            Margin="Margin.Dense"
                                                            Placeholder="XXXXXX"
                                                            Mask="_mask"
                                                            Clearable="true"
                                                            Immediate="true"/>
                                                    </MudForm>
                                                    <MudLoadingButton
                                                        Size="Size.Small"
                                                        Variant="Variant.Filled"
                                                        Color="Color.Success"
                                                        ButtonType="ButtonType.Button"
                                                        Disabled="@(_confirmModel.Code.Length <= 5)"
                                                        OnClick="@(async () => await OnChangeAsync())">
                                                        Verify
                                                    </MudLoadingButton>
                                                    <MudButton
                                                        Size="Size.Small"
                                                        Variant="Variant.Text"
                                                        Color="Color.Info"
                                                        ButtonType="ButtonType.Button"
                                                        Href="@ReturnUrl"
                                                        OnClick="@(() => NavigationManager.NavigateTo(ReturnUrl))">
                                                        Cancel
                                                    </MudButton>
                                                </MudStack>
                                            </MudPaper>
                                            <MudTextM3 Align="Align.Center" Typo="TypoM3.Body" Size="Size.Medium">
                                                Didn't received an email?
                                                <MudLink Typo="Typo.body2" OnClick="@(async () => await OnResendAsync())">
                                                    Resend
                                                </MudLink>
                                            </MudTextM3>
                                        </MudStack>
                                    </MudItem>
                                </MudGrid>
                            </ChildContent>
                        </MudStepExtended>
                    </ChildContent>
                </MudStepperExtended>
            </MudItem>
        </MudGrid>
    </AccessConfirmed>
</AccessConfirmation>

@code {

    [SupplyParameterFromQuery(Name = "type")]
    public string Type { get; set; } = string.Empty;
    
    [SupplyParameterFromQuery(Name = "email")]
    public string Email { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "return_url")]
    public string ReturnUrl { get; set; } = null!;
    
    private ChangeEmailModel _changeModel = new();
    private CodeModel _confirmModel = new();

    private readonly PatternMask _mask = new("000000");
    private MudStepperExtended _stepper = new();
    private MudForm _changeForm = new();
    private MudForm _confirmForm = new();
    private ConfirmationContext? _confirmationContext;

    protected override void OnInitialized()
    {
        _confirmationContext = new ConfirmationContext
        {
            Purpose = PurposeType.Email,
            Action = ActionType.Change
        };
    }

    private async Task OnResendAsync()
    {
        var request = new ResendEmailChangeRequest { NewEmail = _changeModel.NewEmail };
        var result = await EmailService.ResendEmailChangeAsync(request);
        if (!result.Succeeded)
        {
            var error = result.GetError();
            Snackbar.Add(error.Description, Severity.Error);
        }
    }

    private async Task OnSendCode()
    {
        await _changeForm.ValidateAsync();

        if (_changeForm.IsValid)
        {
            var request = new SendEmailChangeRequest { NewEmail = _changeModel.NewEmail };
            var result = await EmailService.SendEmailChangeAsync(request);
            if (result.Succeeded)
            {
                await _stepper.StepNextAsync();
            }
            else
            {
                var error = result.GetError();
                Snackbar.Add(error.Description, Severity.Error);
            }
        }
    }

    private async Task OnChangeAsync()
    {
        await _confirmForm.ValidateAsync();

        if (_confirmForm.IsValid)
        {
            var request = new ConfirmEmailChangeRequest
            {
                Code = _confirmModel.Code,
                NewEmail = _changeModel.NewEmail,
                CurrentEmail = Email
            };

            var result = await EmailService.ConfirmEmailChangeAsync(request);
            if (result.Succeeded)
            {
                Snackbar.Add("Email address was successfully changed", Severity.Success);
                NavigationManager.NavigateTo(ReturnUrl);
            }
            else
            {
                Snackbar.Add(result.GetError().Description, Severity.Error);
            }
        }
    }

}
